{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@zeroclick/domain": [
        "packages/domain/src"
      ],
      "@zeroclick/domain/*": [
        "packages/domain/src/*"
      ],
      "@zeroclick/ui": [
        "packages/ui/src"
      ],
      "@zeroclick/ui/*": [
        "packages/ui/src/*"
      ]
    }
  }
}
